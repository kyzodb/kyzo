#!/usr/bin/env python3
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# board-context — active-story context, next-work context, board signal (#140).
#
# One read pass over GitHub; three generated files; nudges surfaced in the
# board-signal file (and on stdout when run by hand). READ-ONLY by design: the
# board is Kyle's visual signal, kept true by people. This tool notices when
# the board and reality disagree and says so; a human or dev agent updates the
# board intentionally. It never moves cards, never edits issues, never blocks.
#
#   .claude/active-story.md   rich context on the story being worked
#   .claude/next-work.md      what comes next, in board priority order
#   .claude/board-signal.md   does the visible board match actual work?
#
# Priority order lives in exactly one place — the board's Priority field —
# because preserving that order IS the product-owner work this exists to
# surface. There is no local config to drift from it.
#
# Usage:
#   scripts/board-context            # TTL-throttled (no network per keystroke)
#   scripts/board-context --force    # always fetch
#
# Offline / gh failure: keep the existing files (stale context beats invented
# context), warn on stderr, exit 0 — a network blip must never wedge a prompt.

import json
import os
import subprocess
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

ROOT = Path(
    os.environ.get("CLAUDE_PROJECT_DIR")
    or subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
    ).stdout.strip()
    or "."
)
OWNER, REPO, BOARD = "kyzodb", "kyzo", "KyzoDB Work"
TTL_SECONDS = 120
ACTIVE = ROOT / ".claude" / "active-story.md"
NEXT = ROOT / ".claude" / "next-work.md"
SIGNAL = ROOT / ".claude" / "board-signal.md"
HDR = ("<!-- Generated by scripts/board-context from GitHub — do not edit; "
       "the board is the source. -->")
# Evidence comments are marked so "done but missing evidence" is checkable.
EVIDENCE_MARKER = "story-evidence"
# The evidence discipline is only fair to apply to stories closed after the
# tooling existed (this file landed 2026-07-08); older seals carry their proof
# in final reports and merge commits.
EVIDENCE_SINCE = "2026-07-08"
ARTIFACT_LABELS = {"reference", "epic"}  # consumed, not executed


def gh(args):
    r = subprocess.run(["gh"] + args, capture_output=True, text=True)
    if r.returncode != 0:
        raise RuntimeError(f"gh {' '.join(args)}: {r.stderr.strip()}")
    return r.stdout


def first_line(text, limit=140):
    for line in (text or "").strip().splitlines():
        line = line.strip().lstrip("#*> ").strip()
        if line:
            return line[:limit] + ("…" if len(line) > limit else "")
    return ""


def main():
    force = "--force" in sys.argv[1:]
    if not force and ACTIVE.is_file():
        if time.time() - ACTIVE.stat().st_mtime < TTL_SECONDS:
            return 0

    try:
        issues = json.loads(gh(
            ["issue", "list", "--state", "open", "--json",
             "number,title,labels,milestone,body", "--limit", "300"]))
        plist = json.loads(gh(["project", "list", "--owner", OWNER,
                               "--format", "json"]))
        pnum = next(p["number"] for p in plist["projects"] if p["title"] == BOARD)
        items = json.loads(gh(
            ["project", "item-list", str(pnum), "--owner", OWNER,
             "--format", "json", "--limit", "500"]))["items"]
        closed = json.loads(gh(
            ["issue", "list", "--state", "closed", "--json",
             "number,title,closedAt", "--limit", "5"]))
    except (RuntimeError, StopIteration, json.JSONDecodeError) as e:
        print(f"board-context: fetch failed ({e}); keeping existing context",
              file=sys.stderr)
        return 0

    board = {}  # issue number -> {status, priority}
    for it in items:
        n = it.get("content", {}).get("number")
        if n is not None:
            board[n] = {"status": it.get("status"), "priority": it.get("priority")}

    active = [i for i in issues
              if "active-story" in {l["name"] for l in i["labels"]}]
    branch = subprocess.run(
        ["git", "-C", str(ROOT), "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True).stdout.strip()
    now = datetime.now(timezone.utc)

    # ---- next-work: the queue behind the active story ----------------------
    # "Next" means: open issues in the active story's milestone, in the board's
    # Priority order. When nothing is active, it is the front of the earliest
    # Version milestone — the queue an operator would start from.
    if len(active) == 1:
        cur_ms = (active[0].get("milestone") or {}).get("title")
    else:
        vms = sorted({(i.get("milestone") or {}).get("title") or ""
                      for i in issues if (i.get("milestone") or {})
                      .get("title", "").startswith("Version")})
        cur_ms = vms[0] if vms else None
    queue = [i for i in issues
             if (i.get("milestone") or {}).get("title") == cur_ms
             and (len(active) != 1 or i["number"] != active[0]["number"])
             and board.get(i["number"], {}).get("priority") is not None]
    queue.sort(key=lambda i: board[i["number"]]["priority"])
    nxt = queue[:5]

    # ---- active-story.md ----------------------------------------------------
    lines = [HDR]
    if len(active) == 1:
        a = active[0]
        n = a["number"]
        ms = (a.get("milestone") or {}).get("title") or "(none)"
        b = board.get(n, {})
        status = b.get("status") or "(not on board)"
        pri = b.get("priority")
        pri_s = str(int(pri)) if pri is not None else "?"
        try:
            comments = json.loads(gh(
                ["api", f"repos/{OWNER}/{REPO}/issues/{n}/comments?per_page=100"]))
        except (RuntimeError, json.JSONDecodeError):
            comments = []
        # Why now: the queue position is the operator's decision; what waits
        # behind it is the concrete cost of this story stalling.
        behind = ", ".join(f"#{i['number']}" for i in nxt[:3])
        why = (f"priority {pri_s} in `{ms}` — the operator's current top of the "
               f"queue{f'; {behind} wait behind it' if behind else ''}.")
        # Which of the next stories does this story's own body name? That is
        # the dependency thread, in the story's own words.
        named = [i["number"] for i in nxt if f"#{i['number']}" in (a.get("body") or "")]
        lines += [
            f"active_story: #{n}",
            f"title: {a['title']}",
            f"board_status: {status}",
            f"milestone: {ms}",
            f"priority: {pri_s}",
            f"branch: story-{n}-*",
            "",
            f"# Active story: #{n} — {a['title']}",
            "",
            f"**Why now:** {why}",
            "",
            "**Acceptance / evidence needed:** the Acceptance section of the body "
            "below is the boundary; the story moves forward on an evidence "
            "comment (scripts/story-evidence), not on a claim in chat.",
        ]
        if named:
            lines += ["", "**Dependency thread (named by this story's own body):** "
                          + " → ".join(f"#{x}" for x in named)]
        lines += ["", "**Recent decisions (last comments):**"]
        if comments:
            for c in comments[-3:]:
                lines.append(f"- {c['user']['login']} ({c['created_at'][:10]}): "
                             f"{first_line(c['body'])}")
        else:
            lines.append("- (no comments yet)")
        lines += [
            "",
            "**Non-goals:** the body's Non-goals section is law.",
            "",
            "**Do not pull forward:** .claude/next-work.md is context, not "
            "permission — noticing future work is fine; silently implementing "
            "it is not.",
            "",
            f"--- issue #{n} body (verbatim from GitHub) ---",
            a.get("body") or "",
        ]
    elif len(active) == 0:
        lines += [
            "active_story: none",
            "",
            "No open issue carries the `active-story` label — no story is in "
            "flight. Board/doc work may proceed; before code work, choose or "
            "confirm the active story with the operator.",
        ]
    else:
        lines += [
            "active_story: ambiguous",
            "",
            "MULTIPLE issues carry `active-story`: "
            + ", ".join(f"#{i['number']}" for i in active)
            + ". Exactly one story is worked at a time — resolve on the board.",
        ]
    ACTIVE.write_text("\n".join(lines) + "\n")

    # ---- next-work.md --------------------------------------------------------
    lines = [HDR, "", f"# Next work — milestone `{cur_ms}`, board priority order", ""]
    if not nxt:
        lines.append("(no prioritized open issues queued after the active story)")
    for i in nxt:
        n = i["number"]
        labels = {l["name"] for l in i["labels"]}
        tag = (" — reference/epic artifact (consumed, not executed)"
               if labels & ARTIFACT_LABELS
               else " — blocked" if "blocked" in labels else "")
        lines.append(f"{int(board[n]['priority'])}. **#{n} — {i['title']}**{tag}")
        gist = first_line(i.get("body"))
        if gist:
            lines.append(f"   {gist}")
    lines += [
        "",
        "**Why this order:** it is the operator's Priority field on the board — "
        "the product decision this system surfaces rather than re-derives.",
        "",
        "**Connection:** each becomes workable when what is above it lands or "
        "the operator reorders; reference artifacts are read as input to the "
        "stories that follow them.",
        "",
        "**Do not start these yet.** A story starts when the operator moves the "
        "`active-story` label, not before.",
    ]
    NEXT.write_text("\n".join(lines) + "\n")

    # ---- board-signal.md -------------------------------------------------------
    checks = []  # (ok, message)

    if len(active) == 1:
        n = active[0]["number"]
        st = board.get(n, {}).get("status")
        if st is None:
            checks.append((False, f"active story #{n} has no card on the board — add it"))
        elif st not in ("Todo", "To Do", "In Progress"):
            checks.append((False, f"active story #{n} card is '{st}', not To Do / "
                                  "In Progress — update the board or confirm the "
                                  "work should not be active"))
        else:
            checks.append((True, f"active story #{n} card is '{st}'"))
        if branch.startswith("story-"):
            if not branch.startswith(f"story-{n}-"):
                checks.append((False, f"work is happening on branch '{branch}' but "
                                      f"the active story is #{n} — the board does "
                                      "not show what is actually being worked"))
        else:
            checks.append((True, f"current branch '{branch}' (not a story branch; "
                                 "nothing hidden from the board)"))
    elif len(active) == 0:
        if branch.startswith("story-"):
            checks.append((False, f"the board shows no active story, but branch "
                                  f"'{branch}' suggests story work — choose or "
                                  "confirm the active story"))
        else:
            checks.append((True, "no active story, and no story branch checked out"))
    else:
        checks.append((False, f"{len(active)} issues carry `active-story` — "
                              "exactly one story is worked at a time"))

    stale_cards = [n for n, b in board.items()
                   if b.get("status") == "In Progress"
                   and not any(a["number"] == n for a in active)
                   and any(i["number"] == n for i in issues)]
    for n in stale_cards:
        checks.append((False, f"#{n} is In Progress on the board without the "
                              "`active-story` label — stale card, or unconfirmed work"))

    off_board = [i["number"] for i in issues if i["number"] not in board]
    if off_board:
        checks.append((False, "open issues invisible to the board: "
                              + ", ".join(f"#{x}" for x in off_board)))
    no_pri = sorted(n for n, b in board.items()
                    if b.get("priority") is None
                    and any(i["number"] == n for i in issues))
    if no_pri:
        checks.append((False, "issues with no Priority on the board (the next-work "
                              "order is unclear there): "
                              + ", ".join(f"#{x}" for x in no_pri)))

    since = datetime.fromisoformat(EVIDENCE_SINCE).replace(tzinfo=timezone.utc)
    for c in closed:
        closed_at = datetime.fromisoformat(c["closedAt"].replace("Z", "+00:00"))
        if closed_at < since or now - closed_at > timedelta(days=14):
            continue
        try:
            bodies = gh(["api", f"repos/{OWNER}/{REPO}/issues/{c['number']}/comments",
                         "--paginate", "--jq", ".[].body"])
        except RuntimeError:
            continue
        if EVIDENCE_MARKER not in bodies:
            checks.append((False, f"#{c['number']} '{c['title']}' was closed "
                                  "without an evidence comment — post evidence "
                                  "(scripts/story-evidence) before treating it "
                                  "as moved forward"))

    bad = [m for ok, m in checks if not ok]
    lines = [HDR, "",
             f"# Board signal — generated {now.strftime('%Y-%m-%d %H:%M UTC')}",
             "",
             ("**The visible board matches actual work.**" if not bad else
              f"**The board is misleading in {len(bad)} way(s).**"), ""]
    for ok, m in checks:
        lines.append(f"- [{'x' if ok else ' '}] {m}")
    if bad:
        lines += ["",
                  "**Update manually (human or dev agent, intentionally — this "
                  "tool never moves cards or edits issues):**"]
        lines += [f"- {m}" for m in bad]
    lines += ["",
              "If this report looks stale relative to the board, regenerate: "
              "scripts/board-context --force"]
    SIGNAL.write_text("\n".join(lines) + "\n")

    for m in bad:
        print(f"nudge: {m}")
    print(f"board-context: wrote {ACTIVE.name}, {NEXT.name}, {SIGNAL.name} "
          f"({len(bad)} signal item(s))")
    return 0


if __name__ == "__main__":
    sys.exit(main())
