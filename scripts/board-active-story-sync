#!/usr/bin/env bash
#
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# board-active-story-sync — GitHub is the work authority (#140 v1).
#
# The board is the source of truth. The ONE open issue carrying the
# `active-story` label IS the active story. This script fetches that state and
# regenerates `.claude/active-story.md` as a LOCAL PROMPT CACHE derived from
# GitHub — never hand-authored truth.
#
#   zero  active-story issues -> code edits blocked, board-only work may proceed
#   one   active-story issue  -> that is the active story (validated by kind)
#   many  active-story issues -> ambiguous; code edits blocked
#
# The generated file carries a machine-readable front matter block the hooks
# grep (active_story_count / active_story / branch / status / contract). It is
# NEVER edited by hand: the board issue is authoritative.
#
# Usage:
#   scripts/board-active-story-sync            # TTL-throttled sync
#   scripts/board-active-story-sync --force    # always fetch
#   scripts/board-active-story-sync --check    # print parsed state, no write
#
# Offline / gh failure: keep the existing cache (never clobber with a guess),
# warn on stderr, exit 0 so a prompt is never wedged by a network blip.
set -euo pipefail

root="${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || echo .)}"
out="$root/.claude/active-story.md"
ttl_seconds=120
force=0
check_only=0

for arg in "$@"; do
  case "$arg" in
    --force) force=1 ;;
    --check) check_only=1 ; force=1 ;;
    *) printf 'board-active-story-sync: unknown arg %s\n' "$arg" >&2 ; exit 2 ;;
  esac
done

# TTL throttle: an unforced sync within the freshness window is a no-op so the
# UserPromptSubmit hook does not hit the network on every keystroke.
if [ "$force" -eq 0 ] && [ -f "$out" ]; then
  now=$(date +%s)
  mtime=$(stat -c %Y "$out" 2>/dev/null || echo 0)
  if [ $((now - mtime)) -lt "$ttl_seconds" ]; then
    exit 0
  fi
fi

# Fetch the active-story set. On any failure keep the cache and bail softly.
if ! raw=$(gh issue list --label active-story --state open \
             --json number,title,labels,milestone,body --limit 50 2>/dev/null); then
  echo "board-active-story-sync: gh fetch failed; keeping existing cache" >&2
  exit 0
fi

count=$(printf '%s' "$raw" | jq 'length')

# active_ref names the authority state for the board projector + change stamp.
if [ "$count" -eq 0 ]; then
  active_ref="none"
elif [ "$count" -gt 1 ]; then
  active_ref="ambiguous"
else
  active_ref=$(printf '%s' "$raw" | jq -r '.[0].number')
fi

tmp="$out.tmp.$$"
trap 'rm -f "$tmp"' EXIT

hdr='<!-- GENERATED FROM GITHUB by scripts/board-active-story-sync — DO NOT EDIT BY HAND. The board issue is authoritative. -->'

if [ "$count" -eq 0 ]; then
  {
    echo "$hdr"
    echo "active_story_count: 0"
    echo "active_story: none"
    echo "branch: -"
    echo "status: no active story"
    echo "contract: n/a"
    echo
    echo "note:"
    echo "  - No open issue carries the \`active-story\` label. There is no story in flight."
    echo "  - Code edits to first-party source are BLOCKED until the operator labels one"
    echo "    issue \`active-story\` on the board. Board-only and doc work may proceed."
    echo "  - Do NOT self-assign a story. Await the operator's explicit start."
  } >"$tmp"

elif [ "$count" -gt 1 ]; then
  nums=$(printf '%s' "$raw" | jq -r '[.[].number | "#\(.)"] | join(", ")')
  {
    echo "$hdr"
    echo "active_story_count: $count"
    echo "active_story: ambiguous"
    echo "branch: -"
    echo "status: AMBIGUOUS"
    echo "contract: n/a"
    echo
    echo "note:"
    echo "  - MULTIPLE issues carry the \`active-story\` label: $nums."
    echo "  - Exactly one story may be in flight. Code edits are BLOCKED until the board"
    echo "    carries exactly one \`active-story\` issue."
    echo "  - Resolve the ambiguity on the board, then re-sync."
  } >"$tmp"

else
  num=$(printf '%s' "$raw" | jq -r '.[0].number')
  title=$(printf '%s' "$raw" | jq -r '.[0].title')
  body=$(printf '%s' "$raw" | jq -r '.[0].body')

  # Validate the active story against its kind's template. A failing contract
  # does not block the sync — it is recorded so the blast-radius guard can act.
  contract="unchecked"
  if [ -x "$root/scripts/story-contract-check" ]; then
    if "$root/scripts/story-contract-check" "$num" >/dev/null 2>&1; then
      contract="valid"
    else
      contract="INVALID"
    fi
  fi

  {
    echo "$hdr"
    echo "active_story_count: 1"
    echo "active_story: #$num"
    echo "branch: story-$num-*"
    echo "status: in-progress"
    echo "contract: $contract"
    echo
    echo "story: #$num — $title"
    echo
    echo "scope authority:"
    echo "  - This issue body (below, from GitHub) is the acceptance boundary. Non-goals are law."
    echo "  - Work belongs on a \`story-$num-*\` branch, never on main."
    echo "  - Board is authoritative: update the GitHub issue directly. No hidden scratchpad"
    echo "    issue-body drafts; no local markdown standing in for the board."
    echo "  - Completion requires GitHub-visible evidence (scripts/board-story-evidence)."
    echo
    echo "--- issue #$num body (verbatim from GitHub) ---"
    echo "$body"
  } >"$tmp"
fi

if [ "$check_only" -eq 1 ]; then
  # Emit the front matter only; do not touch the cache.
  sed -n '1,7p' "$tmp"
  rm -f "$tmp"
  trap - EXIT
  exit 0
fi

mv "$tmp" "$out"
trap - EXIT

# Project the authority onto the visible board Status field. Change-gated by a
# stamp so we only MUTATE the board when the active story actually changes (the
# label rarely moves); a normal prompt costs nothing. Best-effort — a board
# failure never wedges the prompt. Run with --force to reconcile unconditionally.
stamp="$root/.claude/.project-status.stamp"
key="$count:$active_ref"
prev=""
[ -f "$stamp" ] && prev=$(cat "$stamp" 2>/dev/null || true)
if [ "$force" -eq 1 ] || [ "$key" != "$prev" ]; then
  if [ -x "$root/scripts/board-project-status" ]; then
    if "$root/scripts/board-project-status" "$count" "$active_ref" >/dev/null 2>&1; then
      printf '%s' "$key" >"$stamp"
    fi
  fi
fi
