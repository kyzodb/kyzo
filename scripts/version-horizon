#!/usr/bin/env python3
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# version-horizon — generate .claude/version-horizon.md (#140 v2): the release
# consequence view. Milestones are outcomes; the version story lives HERE, as
# metadata — current repo version, release policy, the active story's version
# dependency, the nearest release-bearing milestone and its gate status, the
# v1.0 freeze horizon, and the post-v1.0 work that must not leak into current
# scope. Offline-safe; exit 0 always.

import json
import os
import re
import subprocess
import sys
from pathlib import Path

import yaml

ROOT = Path(
    os.environ.get("CLAUDE_PROJECT_DIR")
    or subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
    ).stdout.strip()
    or "."
)
OUT = ROOT / ".claude" / "version-horizon.md"
HDR = ("<!-- GENERATED FROM GITHUB by scripts/version-horizon — DO NOT EDIT BY "
       "HAND. The board is authoritative. -->")

POLICY = (
    "Releases are cut from green `main`, one release per sealed story-wave "
    "(RELEASING.md). Pre-1.0 SemVer: `0.Y` (minor) = breaking, `0.Y.Z` (patch) "
    "= compatible; `v1.0.0` is a milestone, not a date (VERSIONING.md). "
    "Milestones are outcomes; only release-bearing milestones carry versions; "
    "an issue's release relation is its `version:*` label."
)


def front_matter(key):
    story = ROOT / ".claude" / "active-story.md"
    if not story.is_file():
        return None
    m = re.search(rf"^{key}:\s*(.+)$", story.read_text(), re.MULTILINE)
    return m.group(1).strip() if m else None


def repo_version():
    m = re.search(r'^version\s*=\s*"([^"]+)"',
                  (ROOT / "Cargo.toml").read_text(), re.MULTILINE)
    return m.group(1) if m else "unknown"


def main():
    outcomes = yaml.safe_load(
        (ROOT / ".board-machine" / "outcomes.yaml").read_text()
    )["milestones"]
    release_bearing = [n for n, m in outcomes.items() if m.get("release_bearing")]

    try:
        issues = json.loads(subprocess.run(
            ["gh", "issue", "list", "--state", "all", "--json",
             "number,title,state,labels,milestone", "--limit", "300"],
            capture_output=True, text=True, check=True,
        ).stdout)
    except (subprocess.CalledProcessError, json.JSONDecodeError):
        print("version-horizon: gh fetch failed; keeping existing file",
              file=sys.stderr)
        return 0

    def with_label(lbl, state=None):
        out = []
        for i in issues:
            if lbl in {l["name"] for l in i["labels"]}:
                if state is None or i["state"].lower() == state:
                    out.append(i)
        return sorted(out, key=lambda i: i["number"])

    active = front_matter("active_story") or "none"
    version_dep = front_matter("version") or "none"

    def gate_lines(label):
        done = with_label(label, "closed")
        open_ = with_label(label, "open")
        lines = [f"  - {len(done)} closed / {len(done) + len(open_)} total"]
        for i in open_:
            lines.append(f"  - [ ] #{i['number']} — {i['title']}")
        for i in done:
            lines.append(f"  - [x] #{i['number']} — {i['title']}")
        return lines

    before_v1_open = [
        i for i in with_label("version:before-v1.0", "open")
        if f"#{i['number']}" != active
    ]
    post_v1_open = with_label("version:post-v1.0", "open")

    lines = [
        HDR,
        "",
        "# Version horizon",
        "",
        f"**Current repo version:** `{repo_version()}` (workspace Cargo.toml)",
        "",
        f"**Release policy:** {POLICY}",
        "",
        f"**Active story:** {active} · version dependency: `{version_dep}`",
        "",
        f"**Release-bearing milestones:** {', '.join(f'`{n}`' for n in release_bearing)}",
        "",
        "**Nearest release-bearing milestone:** `v0.9.0-engine-release-seal` — "
        "v0.9 gate status (`version:v0.9-gate`):",
        *gate_lines("version:v0.9-gate"),
        "",
        "**v1.0 API-freeze horizon** (`version:v1.0-gate`, milestone "
        "`v1.0.0-public-api-freeze`):",
        *gate_lines("version:v1.0-gate"),
        "",
        f"**Before-v1.0 stories not active ({len(before_v1_open)}):** do not "
        "start them; they wait their turn on the board:",
    ]
    lines += [f"  - #{i['number']} — {i['title']}" for i in before_v1_open]
    lines += [
        "",
        f"**Post-v1.0 ({len(post_v1_open)} open):** MUST NOT leak into current "
        "scope. Touching their surfaces requires the pull-forward protocol "
        "(scripts/pull-forward-check), never silent implementation.",
        "",
        "<sub>Generated by scripts/version-horizon. Board is authoritative.</sub>",
    ]
    OUT.write_text("\n".join(lines) + "\n")
    print(f"version-horizon: wrote {OUT}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
