#!/usr/bin/env bash
#
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# board-story-evidence — GitHub-visible completion evidence (#140 v1).
#
# Completion is not a claim in chat; it is a comment on the board. This posts (or
# updates in place) a structured evidence comment on the active story's issue:
# branch, commit range, files touched, gate commands, test counts, benchmark
# evidence, authority nodes touched, remaining open decisions, closure
# recommendation. The stop gate refuses "complete" until this exists.
#
# What it derives automatically (from git): branch, commit range vs main,
# files touched. Everything a machine cannot know honestly (test counts, gate
# result, bench numbers) is passed in or read from a gate report — never
# fabricated.
#
# Usage:
#   scripts/board-story-evidence [--issue N] [--gate-report FILE]
#                                [--tests "PASS/FAIL (+IGNORED)"] [--bench TEXT]
#                                [--authority "Tuple, Domain"] [--open "..."]
#                                [--recommend close|hold] [--note TEXT] [--dry-run]
#
# The issue defaults to the active story parsed from .claude/active-story.md.
set -euo pipefail

root="${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || echo .)}"
story_file="$root/.claude/active-story.md"
marker="<!-- board-story-evidence -->"

issue=""
gate_report=""
tests=""
bench=""
authority=""
open_decisions=""
recommend=""
note=""
dry_run=0

while [ $# -gt 0 ]; do
  case "$1" in
    --issue) issue="$2"; shift 2 ;;
    --gate-report) gate_report="$2"; shift 2 ;;
    --tests) tests="$2"; shift 2 ;;
    --bench) bench="$2"; shift 2 ;;
    --authority) authority="$2"; shift 2 ;;
    --open) open_decisions="$2"; shift 2 ;;
    --recommend) recommend="$2"; shift 2 ;;
    --note) note="$2"; shift 2 ;;
    --dry-run) dry_run=1; shift ;;
    *) echo "board-story-evidence: unknown arg $1" >&2; exit 2 ;;
  esac
done

# Default the issue to the active story parsed from the generated cache.
if [ -z "$issue" ] && [ -f "$story_file" ]; then
  issue=$(grep -m1 '^active_story:' "$story_file" | sed -E 's/^active_story:[[:space:]]*#?//' | tr -d '[:space:]')
fi
case "$issue" in
  ''|none|ambiguous)
    echo "board-story-evidence: no single active story to attach evidence to (issue='$issue')." >&2
    echo "  Label exactly one issue 'active-story' and re-sync first." >&2
    exit 2 ;;
esac

branch=$(git -C "$root" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
base=$(git -C "$root" merge-base main HEAD 2>/dev/null || echo "")
if [ -n "$base" ]; then
  range="$base..HEAD"
  commit_range=$(git -C "$root" log --oneline "$range" 2>/dev/null | sed 's/^/    /')
  files=$(git -C "$root" diff --name-only "$base"...HEAD 2>/dev/null | sed 's/^/    /')
else
  commit_range="    (no merge-base with main)"
  files="    (unknown)"
fi
[ -n "$commit_range" ] || commit_range="    (none)"
[ -n "$files" ] || files="    (none)"

gate_block="    (not provided — attach with --gate-report or --tests)"
if [ -n "$gate_report" ] && [ -f "$gate_report" ]; then
  gate_block=$(sed 's/^/    /' "$gate_report")
elif [ -n "$tests" ]; then
  gate_block="    tests: $tests"
fi

# Assemble the comment.
body=$(cat <<EOF
$marker
## Story evidence — #$issue

**Branch:** \`$branch\`

**Commits (\`main..HEAD\`):**
\`\`\`
$commit_range
\`\`\`

**Files touched:**
\`\`\`
$files
\`\`\`

**Gate / tests:**
\`\`\`
$gate_block
\`\`\`

**Benchmark evidence:** ${bench:-n/a}

**Authority nodes touched:** ${authority:-n/a}

**Remaining open decisions:** ${open_decisions:-none recorded}

**Closure recommendation:** ${recommend:-hold}
${note:+
**Note:** $note}

<sub>Generated by scripts/board-story-evidence. Board is authoritative.</sub>
EOF
)

if [ "$dry_run" -eq 1 ]; then
  printf '%s\n' "$body"
  exit 0
fi

# Update the existing evidence comment in place if present, else create one.
existing_id=$(gh api "repos/{owner}/{repo}/issues/$issue/comments" --paginate \
                --jq ".[] | select(.body | contains(\"$marker\")) | .id" 2>/dev/null | head -1 || true)

if [ -n "$existing_id" ]; then
  printf '%s' "$body" | gh api -X PATCH "repos/{owner}/{repo}/issues/comments/$existing_id" \
    -F body=@- >/dev/null
  echo "board-story-evidence: updated evidence comment on #$issue (id $existing_id)"
else
  printf '%s' "$body" | gh issue comment "$issue" --body-file - >/dev/null
  echo "board-story-evidence: posted evidence comment on #$issue"
fi
