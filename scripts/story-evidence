#!/usr/bin/env bash
#
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# story-evidence — write completion evidence back to the story's issue (#140).
#
# A story moves forward on proof, not on a claim in chat: this posts (or
# updates in place) ONE evidence comment on the issue. What a machine can know
# honestly is derived (branch, commit range vs main, files touched); what it
# cannot (test counts, gate results, acceptance state) is passed in or read
# from a gate report — never fabricated. This is the only place the tooling
# writes to GitHub, and it writes a comment, never board state.
#
# Usage:
#   scripts/story-evidence --issue N [--gate-report FILE] [--tests "P/F (+I)"]
#                          [--commands FILE|TEXT] [--acceptance FILE|TEXT]
#                          [--open "..."] [--recommend close|hold] [--note TEXT]
#                          [--dry-run]
set -euo pipefail

root="${CLAUDE_PROJECT_DIR:-$(git rev-parse --show-toplevel 2>/dev/null || echo .)}"
marker="<!-- story-evidence -->"

issue=""; gate_report=""; tests=""; commands=""; acceptance=""
open_decisions=""; recommend=""; note=""; dry_run=0

text_or_file() { if [ -f "$1" ]; then cat "$1"; else printf '%s' "$1"; fi; }

while [ $# -gt 0 ]; do
  case "$1" in
    --issue) issue="$2"; shift 2 ;;
    --gate-report) gate_report="$2"; shift 2 ;;
    --tests) tests="$2"; shift 2 ;;
    --commands) commands=$(text_or_file "$2"); shift 2 ;;
    --acceptance) acceptance=$(text_or_file "$2"); shift 2 ;;
    --open) open_decisions="$2"; shift 2 ;;
    --recommend) recommend="$2"; shift 2 ;;
    --note) note="$2"; shift 2 ;;
    --dry-run) dry_run=1; shift ;;
    *) echo "story-evidence: unknown arg $1" >&2; exit 2 ;;
  esac
done

if [ -z "$issue" ]; then
  echo "story-evidence: --issue N is required (evidence belongs to a named story)" >&2
  exit 2
fi

branch=$(git -C "$root" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")
base=$(git -C "$root" merge-base main HEAD 2>/dev/null || echo "")
if [ -n "$base" ]; then
  commit_range=$(git -C "$root" log --oneline "$base..HEAD" 2>/dev/null | sed 's/^/    /')
  files=$(git -C "$root" diff --name-only "$base"...HEAD 2>/dev/null | sed 's/^/    /')
fi
[ -n "${commit_range:-}" ] || commit_range="    (none vs main)"
[ -n "${files:-}" ] || files="    (none vs main)"

gate_block="    (not provided — attach with --gate-report or --tests)"
if [ -n "$gate_report" ] && [ -f "$gate_report" ]; then
  gate_block=$(sed 's/^/    /' "$gate_report")
elif [ -n "$tests" ]; then
  gate_block="    tests: $tests"
fi
commands_block="    (not provided — attach with --commands)"
[ -n "$commands" ] && commands_block=$(printf '%s' "$commands" | sed 's/^/    /')

body=$(cat <<EOF
$marker
## Story evidence — #$issue

**Branch:** \`$branch\`

**Commits (\`main..HEAD\`):**
\`\`\`
$commit_range
\`\`\`

**Files touched:**
\`\`\`
$files
\`\`\`

**Commands run:**
\`\`\`
$commands_block
\`\`\`

**Gate / tests:**
\`\`\`
$gate_block
\`\`\`

**Acceptance:**
${acceptance:-(not provided — attach with --acceptance)}

**Remaining open decisions:** ${open_decisions:-none recorded}

**Closure recommendation:** ${recommend:-hold}
${note:+
**Note:** $note}

<sub>Posted by scripts/story-evidence.</sub>
EOF
)

if [ "$dry_run" -eq 1 ]; then
  printf '%s\n' "$body"
  exit 0
fi

existing_id=$(gh api "repos/{owner}/{repo}/issues/$issue/comments" --paginate \
                --jq ".[] | select(.body | contains(\"$marker\")) | .id" 2>/dev/null | head -1 || true)
if [ -n "$existing_id" ]; then
  printf '%s' "$body" | gh api -X PATCH "repos/{owner}/{repo}/issues/comments/$existing_id" \
    -F body=@- >/dev/null
  echo "story-evidence: updated evidence comment on #$issue"
else
  printf '%s' "$body" | gh issue comment "$issue" --body-file - >/dev/null
  echo "story-evidence: posted evidence comment on #$issue"
fi
