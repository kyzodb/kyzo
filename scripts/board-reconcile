#!/usr/bin/env python3
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# board-reconcile — drive the live board toward .board-machine/ target state
# (#140 v2). Dry-run by DEFAULT; nothing mutates without an explicit --apply.
#
# Actions (each printed as a plan line in dry-run, executed under --apply):
#   create missing outcome milestones (from outcomes.yaml)
#   move issues to their target milestones
#   add missing open issues to the KyzoDB Work board
#   set default Status (Todo) for newly added issues
#   add missing version-dependency labels (from version-dependencies.yaml)
#
# UNKNOWNS ARE REPORTED, NEVER GUESSED: an open issue absent from
# outcomes.yaml / version-dependencies.yaml is listed for the operator; no
# classification is invented for it. Renames are config-driven too: to rename
# a milestone, change its name in outcomes.yaml — the old name shows up as
# unknown and the operator retires it deliberately (renames of live GitHub
# milestones preserve issue membership, so they are done via `gh api -X PATCH`
# by the operator or a story, not silently here).
#
# Usage: scripts/board-reconcile [--apply]
# Exit:  0 = nothing to do (or applied cleanly); 1 = actions pending in
#        dry-run or unknowns present; 2 = fetch/config error.

import json
import os
import subprocess
import sys
from pathlib import Path

import yaml

ROOT = Path(
    os.environ.get("CLAUDE_PROJECT_DIR")
    or subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
    ).stdout.strip()
    or "."
)
CONF = ROOT / ".board-machine"
DEFAULT_STATUS = "Todo"


def gh(args):
    r = subprocess.run(["gh"] + args, capture_output=True, text=True)
    if r.returncode != 0:
        raise RuntimeError(f"gh {' '.join(args)}: {r.stderr.strip()}")
    return r.stdout


def gh_json_pages(path):
    raw = gh(["api", path, "--paginate"])
    dec, idx, out = json.JSONDecoder(), 0, []
    while idx < len(raw):
        while idx < len(raw) and raw[idx].isspace():
            idx += 1
        if idx >= len(raw):
            break
        arr, idx = dec.raw_decode(raw, idx)
        out.extend(arr)
    return out


def main():
    apply = "--apply" in sys.argv[1:]
    for a in sys.argv[1:]:
        if a != "--apply":
            print(f"board-reconcile: unknown arg {a}", file=sys.stderr)
            return 2

    outcomes = yaml.safe_load((CONF / "outcomes.yaml").read_text())
    versions = yaml.safe_load((CONF / "version-dependencies.yaml").read_text())
    owner = outcomes["project"]["owner"]
    repo = outcomes["project"]["repo"]
    board_title = outcomes["project"]["board"]

    target_milestone = {}  # issue -> milestone name
    for name, m in outcomes["milestones"].items():
        for n in m["issues"]:
            if n in target_milestone:
                print(f"board-reconcile: #{n} listed under both "
                      f"'{target_milestone[n]}' and '{name}' in outcomes.yaml",
                      file=sys.stderr)
                return 2
            target_milestone[n] = name
    target_labels = {}  # issue -> set of version labels
    for label, nums in versions["assignments"].items():
        for n in nums:
            target_labels.setdefault(n, set()).add(label)

    # ---- live state ---------------------------------------------------------
    issues = [
        i
        for i in gh_json_pages(f"repos/{owner}/{repo}/issues?state=open&per_page=100")
        if "pull_request" not in i
    ]
    live_milestones = {
        m["title"]: m["number"]
        for m in gh_json_pages(f"repos/{owner}/{repo}/milestones?state=open&per_page=100")
    }
    plist = json.loads(gh(["project", "list", "--owner", owner, "--format", "json"]))
    project = next((p for p in plist["projects"] if p["title"] == board_title), None)
    if project is None:
        print(f"board-reconcile: project '{board_title}' not found", file=sys.stderr)
        return 2
    pnum, pid = project["number"], project["id"]
    items = json.loads(
        gh(["project", "item-list", str(pnum), "--owner", owner,
            "--format", "json", "--limit", "500"])
    )["items"]
    on_board = {
        it["content"]["number"]
        for it in items
        if it.get("content", {}).get("number") is not None
    }
    flist = json.loads(
        gh(["project", "field-list", str(pnum), "--owner", owner, "--format", "json"])
    )
    status_field = next(f for f in flist["fields"] if f["name"] == "Status")
    default_opt = next(
        o["id"] for o in status_field["options"] if o["name"] == DEFAULT_STATUS
    )

    # ---- plan ---------------------------------------------------------------
    actions = []   # (description, thunk)
    unknowns = []

    for name in outcomes["milestones"]:
        if name not in live_milestones:
            def mk(name=name):
                gh(["api", "-X", "POST", f"repos/{owner}/{repo}/milestones",
                    "-f", f"title={name}"])
            actions.append((f"create milestone '{name}'", mk))
    for name in live_milestones:
        if name not in outcomes["milestones"]:
            unknowns.append(f"live milestone '{name}' is not in outcomes.yaml "
                            "(retire or add it deliberately)")

    for i in issues:
        n = i["number"]
        labels = {l["name"] for l in i["labels"]}
        milestone = (i.get("milestone") or {}).get("title")

        if n not in target_milestone:
            unknowns.append(f"#{n} '{i['title']}' has no target milestone in "
                            "outcomes.yaml — classify it, don't guess")
        elif milestone != target_milestone[n]:
            want = target_milestone[n]
            def mv(n=n, want=want):
                mnum = live_milestones.get(want)
                if mnum is None:  # created earlier this run
                    mnum = next(
                        m["number"] for m in gh_json_pages(
                            f"repos/{owner}/{repo}/milestones?state=open&per_page=100")
                        if m["title"] == want)
                gh(["api", "-X", "PATCH", f"repos/{owner}/{repo}/issues/{n}",
                    "-F", f"milestone={mnum}"])
            actions.append(
                (f"move #{n} '{milestone or '(none)'}' -> '{want}'", mv))

        if n not in target_labels:
            unknowns.append(f"#{n} '{i['title']}' has no version-dependency "
                            "assignment in version-dependencies.yaml")
        else:
            missing = target_labels[n] - labels
            for lbl in sorted(missing):
                def add(n=n, lbl=lbl):
                    gh(["api", "-X", "POST",
                        f"repos/{owner}/{repo}/issues/{n}/labels",
                        "-f", f"labels[]={lbl}"])
                actions.append((f"label #{n} +{lbl}", add))

        if n not in on_board:
            def board_add(n=n):
                out = json.loads(gh(
                    ["project", "item-add", str(pnum), "--owner", owner,
                     "--url", f"https://github.com/{owner}/{repo}/issues/{n}",
                     "--format", "json"]))
                gh(["project", "item-edit", "--id", out["id"],
                    "--project-id", pid, "--field-id", status_field["id"],
                    "--single-select-option-id", default_opt])
            actions.append(
                (f"add #{n} to board '{board_title}' (Status: {DEFAULT_STATUS})",
                 board_add))

    # ---- report / apply -----------------------------------------------------
    mode = "APPLY" if apply else "DRY-RUN"
    print(f"board-reconcile [{mode}]: {len(actions)} action(s), "
          f"{len(unknowns)} unknown(s)")
    for u in unknowns:
        print(f"  UNKNOWN: {u}")
    for desc, thunk in actions:
        if apply:
            thunk()
            print(f"  applied: {desc}")
        else:
            print(f"  would: {desc}")

    if unknowns:
        return 1
    if actions and not apply:
        return 1
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except RuntimeError as e:
        print(f"board-reconcile: {e}", file=sys.stderr)
        sys.exit(2)
