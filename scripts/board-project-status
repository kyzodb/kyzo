#!/usr/bin/env bash
#
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# board-project-status — project the active-story LABEL authority onto the
# KyzoDB Work project board's Status field, DETERMINISTICALLY (#140 v1).
#
# The label is the authority; this is the mechanism that makes the visible board
# move. Invariant enforced every run:
#
#   * exactly the one active story is "In Progress" (added to the board if it was
#     never on it);
#   * every OTHER card that was "In Progress" drops to "Todo";
#   * "Done" is never touched.
#
# Zero or multiple active stories => nothing is In Progress (all In-Progress
# cards drop to Todo). IDs are resolved by NAME so a board rename cannot break it.
# Best-effort and offline-safe: any gh failure exits 0 without wedging.
#
# Usage:  board-project-status <count> <issue-number|none|ambiguous>
set -euo pipefail

owner="kyzodb"
repo="kyzo"
project_title="KyzoDB Work"

count="${1:-}"
active="${2:-}"
if [ -z "$count" ] || [ -z "$active" ]; then
  echo "usage: board-project-status <count> <issue-number|none|ambiguous>" >&2
  exit 2
fi

# Resolve project number + id by title (rename-resilient).
plist=$(gh project list --owner "$owner" --format json 2>/dev/null) || {
  echo "board-project-status: cannot list projects (offline?)" >&2; exit 0; }
pnum=$(printf '%s' "$plist" | jq -r --arg t "$project_title" '.projects[]|select(.title==$t)|.number' | head -1)
pid=$(printf '%s' "$plist"  | jq -r --arg t "$project_title" '.projects[]|select(.title==$t)|.id'     | head -1)
if [ -z "$pnum" ] || [ -z "$pid" ]; then
  echo "board-project-status: project '$project_title' not found" >&2; exit 0
fi

# Resolve the Status single-select field + the option ids by name.
flist=$(gh project field-list "$pnum" --owner "$owner" --format json 2>/dev/null) || exit 0
sfield=$(printf '%s' "$flist" | jq -r '.fields[]|select(.name=="Status")|.id' | head -1)
opt() { printf '%s' "$flist" | jq -r --arg n "$1" '.fields[]|select(.name=="Status")|.options[]|select(.name==$n)|.id' | head -1; }
inprog=$(opt "In Progress")
todo=$(opt "Todo")
if [ -z "$sfield" ] || [ -z "$inprog" ] || [ -z "$todo" ]; then
  echo "board-project-status: Status field/options not found" >&2; exit 0
fi

items=$(gh project item-list "$pnum" --owner "$owner" --format json --limit 500 2>/dev/null) || exit 0

set_status() { # item-id  option-id
  gh project item-edit --id "$1" --project-id "$pid" --field-id "$sfield" \
    --single-select-option-id "$2" >/dev/null 2>&1 || true
}

target=""
# 1. Drive the single active story to In Progress (adding it to the board if it
#    was never added — the exact gap that left new stories invisible).
if [ "$count" = "1" ] && [ "$active" != "none" ] && [ "$active" != "ambiguous" ]; then
  target="$active"
  iid=$(printf '%s' "$items" | jq -r --argjson n "$target" '.items[]|select(.content.number==$n)|.id' | head -1)
  if [ -z "$iid" ] || [ "$iid" = "null" ]; then
    iid=$(gh project item-add "$pnum" --owner "$owner" \
            --url "https://github.com/$owner/$repo/issues/$target" \
            --format json 2>/dev/null | jq -r '.id')
    echo "board-project-status: #$target was not on the board — added it"
  fi
  if [ -n "$iid" ] && [ "$iid" != "null" ]; then
    set_status "$iid" "$inprog"
    echo "board-project-status: #$target -> In Progress"
  fi
fi

# 2. Reconcile: any other card currently In Progress -> Todo. Never touch Done.
printf '%s' "$items" \
  | jq -r '.items[]|select(.status=="In Progress")|"\(.content.number)\t\(.id)"' \
  | while IFS=$'\t' read -r n iid; do
      [ "$n" = "$target" ] && continue
      set_status "$iid" "$todo"
      echo "board-project-status: #$n In Progress -> Todo (not the active story)"
    done

exit 0
