#!/usr/bin/env python3
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# outcome-context — generate .claude/outcome-context.md (#140 v2): the outcome
# arc around the active story. Purpose of the current outcome, every issue in
# it with a one-line summary, what the outcome unlocks, and what it must not
# absorb. Runway awareness without flooding the agent with the whole board.
#
# Reads the active story from .claude/active-story.md (generated by
# active-story-sync) and the ontology from .board-machine/outcomes.yaml; issue
# titles come from GitHub. Offline-safe: on any fetch failure the existing
# file is kept. Exit 0 always (context generation never wedges a prompt).

import json
import os
import re
import subprocess
import sys
from pathlib import Path

import yaml

ROOT = Path(
    os.environ.get("CLAUDE_PROJECT_DIR")
    or subprocess.run(
        ["git", "rev-parse", "--show-toplevel"], capture_output=True, text=True
    ).stdout.strip()
    or "."
)
OUT = ROOT / ".claude" / "outcome-context.md"
HDR = ("<!-- GENERATED FROM GITHUB by scripts/outcome-context — DO NOT EDIT BY "
       "HAND. The board is authoritative. -->")


def front_matter(key):
    story = ROOT / ".claude" / "active-story.md"
    if not story.is_file():
        return None
    m = re.search(rf"^{key}:\s*(.+)$", story.read_text(), re.MULTILINE)
    return m.group(1).strip() if m else None


def main():
    outcomes = yaml.safe_load(
        (ROOT / ".board-machine" / "outcomes.yaml").read_text()
    )["milestones"]
    milestone = front_matter("milestone")
    active = front_matter("active_story")

    if not milestone or milestone in ("none", "ambiguous"):
        OUT.write_text(
            f"{HDR}\noutcome: none\n\nNo active story, so no current outcome. "
            "The outcome sequence is .board-machine/outcomes.yaml.\n"
        )
        return 0
    if milestone not in outcomes:
        OUT.write_text(
            f"{HDR}\noutcome: UNKNOWN ({milestone})\n\nThe active story's "
            "milestone is not in .board-machine/outcomes.yaml — that is board "
            "drift; run scripts/board-inventory.\n"
        )
        return 0

    o = outcomes[milestone]
    try:
        issues = json.loads(subprocess.run(
            ["gh", "issue", "list", "--state", "all", "--milestone", milestone,
             "--json", "number,title,state", "--limit", "100"],
            capture_output=True, text=True, check=True,
        ).stdout)
    except (subprocess.CalledProcessError, json.JSONDecodeError):
        print("outcome-context: gh fetch failed; keeping existing file",
              file=sys.stderr)
        return 0

    by_num = {i["number"]: i for i in issues}
    lines = [
        HDR,
        f"outcome: {milestone}",
        "",
        f"# Outcome: {milestone}",
        "",
        f"**Purpose:** {o['purpose']}",
        "",
        "**Issues in this outcome:**",
    ]
    for n in o["issues"]:
        i = by_num.get(n)
        if i is None:
            lines.append(f"- #{n} — (not in this milestone on GitHub — drift; "
                         "run scripts/board-inventory)")
            continue
        mark = "x" if i["state"].lower() == "closed" else " "
        star = " ← **active story**" if active == f"#{n}" else ""
        lines.append(f"- [{mark}] #{n} — {i['title']}{star}")
    lines += [
        "",
        f"**Unlocks:** {o['unlocks']}",
        "",
        f"**Must not absorb:** {o['must_not_absorb']}",
        "",
        "<sub>Generated by scripts/outcome-context. Board is authoritative.</sub>",
    ]
    OUT.write_text("\n".join(lines) + "\n")
    print(f"outcome-context: wrote {OUT} ({milestone})")
    return 0


if __name__ == "__main__":
    sys.exit(main())
