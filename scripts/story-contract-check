#!/usr/bin/env bash
#
# Copyright 2026, The KyzoDB Authors. MPL-2.0.
#
# story-contract-check — validate a board issue against its KIND's template (#140 v1).
#
# Not every issue is an engine-implementation story, and forcing one template on
# all of them is a lie. So we resolve the issue's labels + milestone to ONE typed
# kind at the boundary (parse, don't validate), then require only that kind's
# sections. An engine-implementation story owes the full contract; a platform
# story owes Purpose/scope/Acceptance/Hardest obligation; a reference artifact
# owes only substance.
#
# Kind precedence (first match wins):
#   reference -> epic -> product-spike -> proof(benchmark|trial|demo|public-proof)
#   -> platform-story(platform|infra) -> engine-implementation(engine|Engine milestone)
#   -> generic-story(story) -> unclassified
#
# Usage:  scripts/story-contract-check <issue-number>
# Exit:   0 = contract satisfied for its kind; 1 = missing required sections;
#         2 = usage / fetch error.
set -euo pipefail

num="${1:-}"
if [ -z "$num" ]; then
  echo "usage: story-contract-check <issue-number>" >&2
  exit 2
fi

if ! raw=$(gh issue view "$num" --json labels,milestone,body 2>/dev/null); then
  echo "story-contract-check: could not fetch issue #$num" >&2
  exit 2
fi

labels=$(printf '%s' "$raw" | jq -r '[.labels[].name] | join(" ")')
milestone=$(printf '%s' "$raw" | jq -r '.milestone.title // ""')
# Lowercased body for case-insensitive section detection.
body=$(printf '%s' "$raw" | jq -r '.body' | tr '[:upper:]' '[:lower:]')

has_label() { printf ' %s ' "$labels" | grep -q " $1 " ; }
has_section() { printf '%s' "$body" | grep -q "$1" ; }

# --- Resolve the typed kind at the boundary -------------------------------
kind="unclassified"
if   has_label reference ; then kind="reference"
elif has_label epic ; then kind="epic"
elif has_label product ; then kind="product-spike"
elif has_label benchmark || has_label trial || has_label demo || has_label public-proof ; then kind="proof"
elif has_label platform || has_label infra ; then kind="platform-story"
elif has_label engine || printf '%s' "$milestone" | grep -qi '^engine' ; then kind="engine-implementation"
elif has_label story ; then kind="generic-story"
fi

missing=()
require() { has_section "$1" || missing+=("$2") ; }

case "$kind" in
  engine-implementation)
    require "current code evidence" "Current code evidence"
    require "architectural smell"   "Architectural smell"
    require "required invariant"    "Required invariant"
    require "acceptance criteria"   "Acceptance criteria"
    require "non-goals"             "Non-goals"
    require "dependencies"          "Dependencies"
    require "open decisions"        "Open decisions"
    require "hardest obligation"    "Hardest obligation"
    require "failure mode"          "Hardest obligation: Failure mode"
    require "proof"                 "Benchmarks/proofs or Hardest-obligation Proof"
    ;;
  platform-story)
    require "purpose"            "Purpose"
    require "acceptance"         "Acceptance"
    require "hardest obligation" "Hardest obligation"
    require "failure mode"       "Hardest obligation: Failure mode"
    if ! has_section "scope" && ! has_section "required design" && ! has_section "design"; then
      missing+=("Scope / Required design")
    fi
    ;;
  generic-story)
    require "acceptance"         "Acceptance"
    require "non-goals"          "Non-goals"
    require "hardest obligation" "Hardest obligation"
    ;;
  reference|epic|product-spike|proof)
    # Substance floor only — these carry their own free-form templates.
    if [ "${#body}" -lt 200 ]; then
      missing+=("a substantive body (>=200 chars)")
    fi
    ;;
  unclassified)
    echo "story-contract-check: #$num is unclassified (no story/reference/epic/... label) — no contract enforced" >&2
    exit 0
    ;;
esac

if [ "${#missing[@]}" -eq 0 ]; then
  echo "story-contract-check: #$num OK (kind=$kind)"
  exit 0
fi

echo "story-contract-check: #$num FAILS contract (kind=$kind). Missing:" >&2
for m in "${missing[@]}"; do echo "  - $m" >&2; done
exit 1
