%% architecture-map default template.
%%
%% Copy this file's structure for a real project: replace "myproject" and the example
%% zones with the real codebase name(s) and real top-level zone paths as they exist
%% in the repository. Keep the schema — see architecture-map/SKILL.md:
%%   - one node per real zone, id = real zone path
%%   - label lines: "<path><br/>status: current|deprecated|target<br/>truth: <one line>"
%%   - deprecated -->|migrates to| target, exactly one edge per deprecated node
%%   - subgraph per codebase when a project spans more than one
%%
%% This example shows all three statuses and the one relationship that matters: a
%% deprecated zone naming exactly where it's going.

graph TD
    subgraph myproject["myproject (codebase)"]
        src_auth["src/auth<br/>status: current<br/>truth: who is making this request"]
        src_legacy_auth["src/legacy_auth<br/>status: deprecated<br/>truth: the old session-cookie login path — superseded, not yet removed"]
        src_identity["src/identity<br/>status: target<br/>truth: the unified identity zone legacy_auth is migrating into"]
    end

    src_legacy_auth -->|migrates to| src_identity

    classDef current fill:#1e4d33,color:#ffffff,stroke:#0f2b1c
    classDef deprecated fill:#7a1f1f,color:#ffffff,stroke:#3d0f0f
    classDef target fill:#2f2f7a,color:#ffffff,stroke:#17173d

    class src_auth current
    class src_legacy_auth deprecated
    class src_identity target
