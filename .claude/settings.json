{
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(cargo-deny:*)",
      "Bash(cargo-vet:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(rustup:*)",
      "Bash(shellcheck:*)",
      "Bash(python3:*)",
      "Bash(jq:*)",
      "Bash(scripts/*)",
      "Bash(.claude/hooks/*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(just:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/blast-radius-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-guard.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-board-context.sh"
          }
        ]
      }
    ]
  }
}
